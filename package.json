{
  "name": "gabrielborges-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "build": "tsc && vite build && npm run prerender",
    "preview": "vite preview",
    "prerender": "tsx scripts/prerender.ts",
    "deploy": "tsc && vite build && npm run prerender && vite preview --host",
    "lighthouse": "cross-env CHROME_PATH=\"C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe\" lighthouse http://localhost:4173 --chrome-flags=\"--headless\" --only-categories=performance",
    "lighthouse:report": "cross-env CHROME_PATH=\"C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe\" lighthouse http://localhost:4173 --chrome-flags=\"--headless\" --only-categories=performance --view --output html --output-path ./lighthouse-report.html"
  },
  "dependencies": {
    "framer-motion": "^11.11.11",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "lighthouse": "^13.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "terser": "^5.46.1",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7"
  }
}
